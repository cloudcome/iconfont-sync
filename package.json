{
  "name": "iconfont-sync",
  "version": "1.1.3",
  "description": "iconfont sync tool",
  "keywords": [
    "cloudcome",
    "iconfont",
    "sync"
  ],
  "homepage": "https://github.com/cloudcome/iconfont-sync",
  "license": "MIT",
  "author": "云淡然 <hi@ydr.me> (https://ydr.me/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudcome/iconfont-sync.git"
  },
  "bin": {
    "iconfont-sync": "bin/index.cjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "lefthook install",
    "lint": "biome check && tsc --noEmit",
    "lint:fix": "biome check --fix --unsafe && tsc --noEmit",
    "build": "cross-env NODE_ENV=production vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@lerna-lite/cli": "^5.2.1",
    "@lerna-lite/version": "^5.2.1",
    "@types/node": "24",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "lefthook": "^2.1.6",
    "taze": "^19.11.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@cloudcome/utils-core": "^1.19.1",
    "extract-zip": "^2.0.1"
  }
}
